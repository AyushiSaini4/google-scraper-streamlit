import streamlit as st
from twilio.rest import Client

def run():
    st.subheader("💬 Send WhatsApp Message via Twilio")

    st.markdown("⚠️ Recipient must have joined your Twilio Sandbox and saved the number in WhatsApp.")

    # Twilio Credentials
    account_sid = st.text_input("Twilio Account SID", type="password")
    auth_token = st.text_input("Twilio Auth Token", type="password")
    sender = "whatsapp:+14155238886"  # Twilio sandbox WhatsApp number (default)
    recipient = st.text_input("Recipient WhatsApp Number (with country code)", "whatsapp:+91")
    message_body = st.text_area("Message", "Hello from Python via WhatsApp API! 🚀")

    if st.button("Send WhatsApp Message"):
        try:
            client = Client(account_sid, auth_token)
            message = client.messages.create(
                from_=sender,
                body=message_body,
                to=recipient
            )
            st.success(f"✅ Message sent successfully! SID: {message.sid}")
        except Exception as e:
            st.error(f"❌ Failed to send message: {e}")
